# Copy to .env and fill in. Restart dev server after changes.

# Required for all Ecwid embeds (Dashboard → Store profile, or any product URL).
VITE_ECWID_STORE_ID=

# Optional: root category for /shop grid (numeric ID from Ecwid).
# VITE_ECWID_DEFAULT_CATEGORY_ID=

# Origin pages: set each when the product exists in Ecwid.
# VITE_ECWID_PRODUCT_COSTA_RICA=
VITE_ECWID_PRODUCT_GUATEMALA=825208083

# Full URL to Antigua Ember product page on Ecwid (home tile + Shop → Guatemala). Paste from Ecwid Catalog → product → open in browser.
# VITE_ECWID_GUATEMALA_PRODUCT_URL=https://your-store.ecwid.com/...

# VITE_ECWID_PRODUCT_INDONESIA=
# VITE_ECWID_PRODUCT_PERU=
# Copán Rise (Honduras) — Ecwid product-browser embed on home + Honduras page (default 825208085 in code).
# VITE_ECWID_PRODUCT_HONDURAS=825208085

# Subscription page — Ecwid product ID for your club / box product.
# VITE_ECWID_SUBSCRIPTION_PRODUCT_ID=

# --- Newsletter (/offers) — configure in Vercel Project → Environment Variables (server-side, not VITE_)
# Pick ONE: webhook (Zapier/Make → Klaviyo, Mailchimp, etc.) OR native integration.
#
# Zapier/Make: catch hook → create/update contact → start automation.
# NEWSLETTER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...
#
# Mailchimp Marketing API (key ends with e.g. -us21):
# MAILCHIMP_API_KEY=
# MAILCHIMP_AUDIENCE_ID=
#
# Brevo / Sendinblue (server secrets for /api/subscribe):
# BREVO_API_KEY=
# BREVO_LIST_IDS=2
#
# Brevo site tracker (public — Marketing → Automations → install snippet; safe in browser):
# VITE_BREVO_CLIENT_KEY=
#
# Local dev: run `vercel dev` so /api/subscribe exists, OR set:
# VITE_NEWSLETTER_API_URL=https://your-site.vercel.app/api/subscribe
